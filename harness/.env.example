# Quest Benchmark Harness — environment variables
# Copy this to harness/.env and fill in your keys.

# --- Main track (OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_key_here
# Answerer model: anthropic/claude-sonnet-4.6
# Judge model: anthropic/claude-opus-4.8

# --- Open track (Ollama Cloud / local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key_here
# Answerer model: deepseek-v4-pro
# Judge model: qwen3.5:397b

# --- Anthropic direct (optional) ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- OpenAI direct (optional, for tool-internal LLMs) ---
OPENAI_API_KEY=your_openai_key_here

# --- Database URLs (for adapters that need them) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/quest
REDIS_URL=redis://localhost:6379/0

# --- Paths ---
LOCOMO_DATA_PATH=../data/locomo.json
RESULTS_DIR=../results
OBSIDIAN_VAULT_PATH=../vault
